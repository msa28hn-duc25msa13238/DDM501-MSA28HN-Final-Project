# Copy to .env and adjust (optional; defaults match TrainingConfig / AppSettings).

# Data & model paths
DATA_DIR=m5_data
MODEL_DIR=models
MODEL_PATH=models/forecast_model.pkl
MODEL_ARTIFACT_NAME=forecast_model.pkl

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Reproducibility (ingestion sample, sklearn HGBR, global NumPy/Python seed)
RANDOM_STATE=42

# API (optional overrides)
APP_TITLE=M5 Demand Forecast API
APP_VERSION=1.0.0
